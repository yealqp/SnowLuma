{
  "name": "@snowluma/ui",
  "author": {
    "name": "MotricSeven",
    "email": "motricseven@gmail.com"
  },
  "version": "1.9.3",
  "description": "Shared SnowLuma UI primitives — Tailwind 4 theme tokens + shadcn-style atomic components",
  "keywords": [
    "snowluma",
    "ui",
    "shadcn",
    "tailwind",
    "react"
  ],
  "homepage": "https://github.com/SnowLuma/SnowLuma#readme",
  "bugs": {
    "url": "https://github.com/SnowLuma/SnowLuma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SnowLuma/SnowLuma.git",
    "directory": "packages/ui"
  },
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles/theme.css": "./src/styles/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "clean": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slot": "^1.1.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.0",
    "typescript": "catalog:"
  }
}
