{
  "name": "@snowluma/bridge",
  "version": "1.9.3",
  "private": true,
  "type": "module",
  "description": "SnowLuma bridge — QQ NT desktop client lifecycle: hook injection (via native addon), per-PID HookSession orchestration, pipe-watcher for process discovery, and the BridgeManagerSink interface that lets the hook layer call back into a UIN-keyed session router without depending on @snowluma/core. Consumed by the top-level app entry (which constructs the BridgeManager from @snowluma/core and injects it as the sink) and by the WebUI server (read-only HookProcessInfo views).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./hook-manager": {
      "types": "./src/hook-manager.ts",
      "default": "./src/hook-manager.ts"
    },
    "./hook-session": {
      "types": "./src/hook-session.ts",
      "default": "./src/hook-session.ts"
    },
    "./hook-packet-client": {
      "types": "./src/hook-packet-client.ts",
      "default": "./src/hook-packet-client.ts"
    },
    "./injector": {
      "types": "./src/injector.ts",
      "default": "./src/injector.ts"
    },
    "./pipe-watcher": {
      "types": "./src/pipe-watcher.ts",
      "default": "./src/pipe-watcher.ts"
    },
    "./qq-hook-client": {
      "types": "./src/qq-hook-client.ts",
      "default": "./src/qq-hook-client.ts"
    },
    "./qq-port-probe": {
      "types": "./src/qq-port-probe.ts",
      "default": "./src/qq-port-probe.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/common": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "^4.1.4"
  }
}
