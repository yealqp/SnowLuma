{
  "name": "@snowluma/core",
  "version": "1.9.3",
  "description": "SnowLuma core - NTQQ packet sniffer with Node.js native addon",
  "private": true,
  "type": "module",
  "main": "../../dist/index.mjs",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "../../dist/index.mjs"
    },
    "./bridge": {
      "types": "./src/bridge/bridge.ts",
      "default": "./src/bridge/bridge.ts"
    },
    "./bridge-interface": {
      "types": "./src/bridge/bridge-interface.ts",
      "default": "./src/bridge/bridge-interface.ts"
    },
    "./bridge-context": {
      "types": "./src/bridge/bridge-context.ts",
      "default": "./src/bridge/bridge-context.ts"
    },
    "./manager": {
      "types": "./src/bridge/manager.ts",
      "default": "./src/bridge/manager.ts"
    },
    "./apis": {
      "types": "./src/bridge/apis/index.ts",
      "default": "./src/bridge/apis/index.ts"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:all": "cross-env BUILD_WEBUI=true vite build",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/bridge": "workspace:*",
    "@snowluma/common": "workspace:*",
    "@snowluma/onebot": "workspace:*",
    "@snowluma/protocol": "workspace:*",
    "@snowluma/proto-defs": "workspace:*",
    "@snowluma/proton": "workspace:*",
    "@snowluma/websocket": "workspace:*"
  },
  "devDependencies": {
    "@hono/node-server": "^1.19.14",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^24.12.2",
    "cross-env": "^10.1.0",
    "hono": "^4.12.18",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-cp": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
