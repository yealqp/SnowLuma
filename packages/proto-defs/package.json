{
  "name": "@snowluma/proto-defs",
  "version": "1.9.3",
  "private": true,
  "type": "module",
  "description": "SnowLuma QQ/Lagrange wire-protobuf type definitions. Pure TypeScript interfaces with proton's `pb<N, T>` marker types — `@snowluma/proton`'s vite plugin compiles them into zero-runtime encoder/decoder functions at the call sites in `@snowluma/core` (and any downstream consumer). Exposed as per-file subpaths (`@snowluma/proto-defs/oidb`, `@snowluma/proto-defs/message`, …) so the import-site shape mirrors the legacy `bridge/proto/proton/*` layout and avoids name collisions across files (notably `highway.ts` and `oidb-actions/media.ts` share NTV2-prefixed names).",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./action": {
      "types": "./src/action.ts",
      "default": "./src/action.ts"
    },
    "./element": {
      "types": "./src/element.ts",
      "default": "./src/element.ts"
    },
    "./highway": {
      "types": "./src/highway.ts",
      "default": "./src/highway.ts"
    },
    "./longmsg": {
      "types": "./src/longmsg.ts",
      "default": "./src/longmsg.ts"
    },
    "./message": {
      "types": "./src/message.ts",
      "default": "./src/message.ts"
    },
    "./notify": {
      "types": "./src/notify.ts",
      "default": "./src/notify.ts"
    },
    "./oidb": {
      "types": "./src/oidb.ts",
      "default": "./src/oidb.ts"
    },
    "./oidb-action": {
      "types": "./src/oidb-action.ts",
      "default": "./src/oidb-action.ts"
    },
    "./oidb-actions/base": {
      "types": "./src/oidb-actions/base.ts",
      "default": "./src/oidb-actions/base.ts"
    },
    "./oidb-actions/group-album": {
      "types": "./src/oidb-actions/group-album.ts",
      "default": "./src/oidb-actions/group-album.ts"
    },
    "./oidb-actions/group-file": {
      "types": "./src/oidb-actions/group-file.ts",
      "default": "./src/oidb-actions/group-file.ts"
    },
    "./oidb-actions/media": {
      "types": "./src/oidb-actions/media.ts",
      "default": "./src/oidb-actions/media.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@snowluma/proton": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "catalog:"
  }
}
