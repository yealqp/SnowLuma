{
  "name": "@snowluma/sdk",
  "author": {
    "name": "MotricSeven",
    "email": "motricseven@gmail.com"
  },
  "version": "1.9.10",
  "description": "TypeScript SDK for SnowLuma OneBot HTTP and WebSocket transports",
  "keywords": [
    "snowluma",
    "onebot",
    "onebot11",
    "qq",
    "bot",
    "sdk"
  ],
  "homepage": "https://github.com/SnowLuma/SnowLuma#readme",
  "bugs": {
    "url": "https://github.com/SnowLuma/SnowLuma/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SnowLuma/SnowLuma.git",
    "directory": "packages/sdk"
  },
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./messages": {
      "types": "./dist/messages/index.d.ts",
      "import": "./dist/messages/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/actions.*",
    "dist/client",
    "dist/emitter.*",
    "dist/errors.*",
    "dist/events",
    "dist/index.*",
    "dist/internal",
    "dist/messages",
    "dist/types",
    "README.md",
    "CHANGELOG.md",
    "VERSIONING.md"
  ],
  "scripts": {
    "clean": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "pnpm run clean",
    "build": "tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "catalog:",
    "vitest": "^4.1.4"
  }
}
